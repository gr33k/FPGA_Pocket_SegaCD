# CANDIDATE ONLY
# OPENFPGA-GENESIS SOURCE LANE
# MIRRORS UPSTREAM PROJECT INTENT
# DO NOT RUN SYNTHESIS FROM THIS FILE YET
# DO NOT INCLUDE UNTIL QUARTUS HOST VALIDATION
# CANDIDATE FILE mirrors upstream ap_core.qsf only for planning
# GENESIS ONLY
# SEGA CD EXCLUDED
# 32X EXCLUDED
# GENESIS_MISTER REFERENCE ONLY

# Device and top-level alignment are copied from upstream openFPGA-Genesis planning
# assumptions and remain non-active until Quartus-host validation confirms parity.
set_global_assignment -name DEVICE 5CEBA4F23C8
set_global_assignment -name TOP_LEVEL_ENTITY apf_top
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 21.1

# Candidate active files (openFPGA-Genesis lane)
set_global_assignment -name VERILOG_FILE ../third_party/openFPGA-Genesis/src/fpga/apf/apf_top.v
set_global_assignment -name SYSTEMVERILOG_FILE ../third_party/openFPGA-Genesis/src/fpga/core/core_top.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../third_party/openFPGA-Genesis/src/fpga/core/rtl/system.sv

